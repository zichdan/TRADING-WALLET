<script>

window.onload = function() {

    const marquee = document.querySelector('.home_page #marquee');
    const marquee_sub = document.querySelector('.home_page #marquee_sub');
    
    function hueRotateEffect() {
        let hue = 0;

        setInterval(() => {
            hue = (hue + 10); 
            console.log(hue);
            marquee.style.filter = 'hue-rotate(' + hue + 'deg)';
        }, 5000);
        
        
    }

    setTimeout(() => {
        // hueRotateEffect();
    }, 0); 





    var angle1 = 315;
    var angle2 = 75;
    
    var pos1 = 238.5 + Math.sin(angle1 * Math.PI / 180) * 1;
    var pos2 = 218 + Math.cos(angle2 * Math.PI / 180) * 1;
    var dir1 = 1;
    var dir2 = 1;

    function updateBackground() {
        
        if (angle1 >= 335) dir1 = -1;
        if (angle1 <= 295) dir1 = 1;
        if (angle2 >= 85) dir2 = -1;
        if (angle2 <= 65) dir2 = 1;

        angle1 = angle1 + (0.02 * dir1);
        angle2 = angle2 + (0.015 * dir2);
        pos1 = 238.5 + Math.sin(angle1 * Math.PI / 180) * 1;
        pos2 = 218 + Math.cos(angle2 * Math.PI / 180) * 1;

        var background = 'repeating-linear-gradient(' + angle1 + 'deg, #68a9a912 85%, #073AFF00 100%), repeating-radial-gradient(' + angle2 + '% ' + angle2 + '% at ' + pos1 + '% ' + pos2 + '%, #00ffff0a 20%, #073AFF14 39%), radial-gradient(99% 99% at 109% 2%, #2950b5 0, #073AFF00 100%), radial-gradient(99% 99% at 21% 78%, #9756565c 0, #073AFF00 100%),';

        if (window.innerWidth <= 991) {
            background += ' radial-gradient(160% 234% at 91px -233px, #ff0000b5 0, #1433a9 76%)';
        } else {
            background += ' radial-gradient(160% 154% at 711px -303px, #ff0000b5 0, #1433a9 100%)';
        }

        var background2 = 'repeating-linear-gradient(' + angle1 + 'deg, #68a9a912 85%, #073AFF00 100%), repeating-radial-gradient(' + angle2 + '% ' + angle2 + '% at ' + pos1 + '% ' + pos2 + '%, #00ffff0a 20%, #073AFF14 39%), radial-gradient(99% 99% at 109% 2%, #2950b5 0, #073AFF00 100%), radial-gradient(99% 99% at 21% 78%, #9756565c 0, #073AFF00 100%), radial-gradient(160% 234% at 91px -193px,#ff0000b5 0,#1433a9 80%)';
        
        marquee.style.background = background;
        marquee_sub.style.background = background2;
    }

    
    setTimeout(() => {
        setInterval(updateBackground, 100);
    }, 500);
}
</script>
